        <dir>
            <info compressed="false">https://raw.githubusercontent.com/gorpet/gorpet.github.io/master/repo/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/gorpet/gorpet.github.io/master/repo/zips/addons.xml.md5</checksum>
